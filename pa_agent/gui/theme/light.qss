/* PA Agent — light trading terminal */

QMainWindow, QWidget {
    background-color: #f5f7fa;
    color: #1f2937;
    font-family: "Segoe UI", "Microsoft YaHei UI", sans-serif;
    font-size: 13px;
}

QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e5e7eb;
    padding: 2px;
}
QMenuBar::item:selected {
    background-color: #f3f4f6;
}
QMenu {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
}
QMenu::item:selected {
    background-color: #f3f4f6;
}

QStatusBar {
    background-color: #ffffff;
    border-top: 1px solid #e5e7eb;
    color: #6b7280;
}

QTabWidget::pane {
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    background-color: #ffffff;
    top: -1px;
}
QTabWidget::pane QScrollBar:vertical {
    width: 10px;
}
QTabBar::tab {
    background-color: #f5f7fa;
    color: #6b7280;
    border: 1px solid #e5e7eb;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 6px 14px;
    margin-right: 2px;
}
QTabBar::tab:selected {
    background-color: #ffffff;
    color: #1f2937;
    border-bottom: 2px solid #3b82f6;
}
QTabBar::tab:hover:!selected {
    color: #1f2937;
    background-color: #e5e7eb;
}

QGroupBox {
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    margin-top: 10px;
    padding-top: 8px;
    font-weight: bold;
    color: #6b7280;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
}

QCheckBox {
    color: #1f2937;
    spacing: 8px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    background-color: #ffffff;
}
QCheckBox::indicator:hover {
    border-color: #3b82f6;
}
QCheckBox::indicator:checked {
    background-color: #10b981;
    border-color: #10b981;
}
QCheckBox::indicator:checked:hover {
    background-color: #34d399;
}
QCheckBox:disabled {
    color: #9ca3af;
}

QPushButton {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 6px 14px;
    min-height: 24px;
}
QPushButton:hover {
    background-color: #f3f4f6;
    border-color: #3b82f6;
}
QPushButton:pressed {
    background-color: #e5e7eb;
}
QPushButton:disabled {
    color: #9ca3af;
    background-color: #f5f7fa;
}
QPushButton#primaryButton {
    background-color: #10b981;
    border-color: #059669;
    font-weight: bold;
    color: #ffffff;
}
QPushButton#primaryButton:hover {
    background-color: #059669;
}
QPushButton#dangerButton {
    border-color: #ef4444;
    color: #ef4444;
}
QPushButton#dangerButton:hover {
    background-color: rgba(239,68,68,0.1);
}

QLineEdit, QPlainTextEdit, QTextEdit, QSpinBox, QComboBox {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 4px 8px;
    selection-background-color: #3b82f666;
}
QLineEdit:focus, QPlainTextEdit:focus, QTextEdit:focus, QSpinBox:focus, QComboBox:focus {
    border-color: #3b82f6;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    selection-background-color: #f3f4f6;
}

QPlainTextEdit#chatInput {
    min-height: 56px;
}

QScrollArea {
    border: none;
    background-color: transparent;
}
QScrollBar:vertical {
    background: #f5f7fa;
    width: 10px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #d1d5db;
    border-radius: 5px;
    min-height: 24px;
}
QScrollBar::handle:vertical:hover {
    background: #9ca3af;
}

QProgressBar {
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    background-color: #f5f7fa;
    text-align: center;
    color: #6b7280;
    max-height: 14px;
}
QProgressBar::chunk {
    background-color: #3b82f6;
    border-radius: 4px;
}
QProgressBar#tokenProgress::chunk {
    background-color: #3b82f6;
}
QProgressBar#tokenProgress[yellow="true"]::chunk {
    background-color: #f59e0b;
}
QProgressBar#tokenProgress[red="true"]::chunk {
    background-color: #ef4444;
}

QSplitter::handle {
    background-color: #e5e7eb;
    width: 2px;
}

QToolButton {
    background: transparent;
    color: #10b981;
    border: none;
    padding: 4px;
    text-align: left;
}
QToolButton:hover {
    color: #059669;
}

QLabel#toolbarTitle {
    font-size: 15px;
    font-weight: bold;
    color: #1f2937;
}
QLabel#mutedLabel {
    color: #6b7280;
    font-size: 11px;
}
QLabel#stageHeader {
    font-size: 14px;
    font-weight: bold;
    color: #3b82f6;
}

QFrame#aiTurnCard {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
}
QFrame#reasoningFrame {
    background-color: #f5f7fa;
    border-left: 3px solid #10b981;
    border-radius: 6px;
}
QTextEdit#reasoningPane, QPlainTextEdit#reasoningPane {
    background-color: #f5f7fa;
    color: #059669;
    border: none;
    font-family: "JetBrains Mono", "Cascadia Mono", "Consolas", monospace;
    font-size: 12px;
}
QTextEdit#answerPane, QPlainTextEdit#answerPane {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    font-family: "JetBrains Mono", "Cascadia Mono", "Consolas", monospace;
    font-size: 12px;
}

QListWidget#timelineList {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    font-size: 11px;
}
QListWidget#timelineList::item {
    padding: 8px 10px;
    border-bottom: 1px solid #f3f4f6;
}
QListWidget#timelineList::item:hover {
    background-color: #f5f7fa;
}
QListWidget#timelineList::item:selected {
    background-color: rgba(59,130,246,0.15);
    color: #3b82f6;
}

/* Tables & trees */
QTableWidget, QTableView, QTreeWidget, QTreeView {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    gridline-color: #f3f4f6;
    alternate-background-color: #f9fafb;
    outline: none;
}
QTableWidget::item, QTableView::item, QTreeWidget::item, QTreeView::item {
    padding: 5px 8px;
    color: #1f2937;
    border: none;
}
QTableWidget::item:alternate, QTableView::item:alternate {
    background-color: #f9fafb;
    color: #1f2937;
}
QTableWidget::item:selected, QTableView::item:selected,
QTreeWidget::item:selected, QTreeView::item:selected {
    background-color: rgba(59,130,246,0.15);
    color: #1f2937;
}
QTableWidget::item:hover, QTableView::item:hover,
QTreeWidget::item:hover, QTreeView::item:hover {
    background-color: #f5f7fa;
}
QHeaderView::section {
    background-color: #f5f7fa;
    color: #6b7280;
    border: none;
    border-bottom: 1px solid #e5e7eb;
    border-right: 1px solid #e5e7eb;
    padding: 6px 8px;
    font-weight: bold;
}
QTableCornerButton::section {
    background-color: #f5f7fa;
    border: none;
}

QTableWidget#pathReplayTable {
    background-color: #ffffff;
}
QTableWidget#pathReplayTable::item:selected {
    background-color: rgba(59,130,246,0.15);
}

QTreeWidget#decisionTreeView {
    background-color: #ffffff;
}
QTreeWidget#decisionTreeView::item:selected {
    background-color: rgba(59,130,246,0.15);
}

QDialog {
    background-color: #ffffff;
}

/* Pill labels */
QLabel#pillGreen {
    color: #059669;
    background-color: rgba(16,185,129,0.1);
    border: 1px solid rgba(16,185,129,0.35);
    border-radius: 6px;
    padding: 2px 8px;
}
QLabel#pillRed {
    color: #dc2626;
    background-color: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.35);
    border-radius: 6px;
    padding: 2px 8px;
}
QLabel#pillAmber {
    color: #d97706;
    background-color: rgba(245,158,11,0.1);
    border: 1px solid rgba(245,158,11,0.35);
    border-radius: 6px;
    padding: 2px 8px;
}
QLabel#pillBlue {
    color: #2563eb;
    background-color: rgba(59,130,246,0.1);
    border: 1px solid rgba(59,130,246,0.35);
    border-radius: 6px;
    padding: 2px 8px;
}
QLabel#pillCyan {
    color: #0891b2;
    background-color: rgba(8,145,178,0.1);
    border: 1px solid rgba(8,145,178,0.35);
    border-radius: 6px;
    padding: 2px 8px;
}